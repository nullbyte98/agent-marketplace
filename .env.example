# Database. Postgres. For Vercel use Vercel Postgres or Neon; for local dev,
# point at any Postgres (e.g. a local container) or use the Vercel Postgres URL
# via `vercel env pull`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agent_marketplace?schema=public"

# Solana
SOLANA_RPC_URL="https://api.devnet.solana.com"
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
# Devnet USDC mint, hard-coded by the user spec
USDC_MINT="4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU"
# Anchor program ID. Replace after first deploy. The placeholder value matches
# the declare_id! in programs/marketplace_escrow/src/lib.rs.
NEXT_PUBLIC_ESCROW_PROGRAM_ID="CZD9e8HA3nuirtb1AgQ7wv4nFYgELjnhAS7PXwDzmZCC"

# The platform keypair, used by the Next.js backend to sign escrow release
# and refund transactions on behalf of agents and the admin. This is base58
# of a 64-byte secret key. Generate with: solana-keygen new --no-bip39-passphrase -o platform-key.json
# then: cat platform-key.json | jq -r 'tostring' (or use the helper script).
PLATFORM_KEYPAIR_BASE58=""

# Admin wallet, the public key that is allowed to resolve disputes.
ADMIN_WALLET_PUBKEY=""

# Anthropic. Used only by the llm_judged verification route.
ANTHROPIC_API_KEY=""

# Optional: a salt used when hashing agent API keys. Set to any random string.
API_KEY_HASH_SALT="change-me-in-production"
